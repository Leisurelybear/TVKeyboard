<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F23">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A35"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 TV 远程输入"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textSize="13sp"
            android:textColor="#888888" />

    </LinearLayout>

    <!-- 未连接状态 -->
    <LinearLayout
        android:id="@+id/layout_disconnected"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="扫描电视上的二维码\n开始远程输入"
            android:textSize="18sp"
            android:textColor="#AAAACC"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_scan"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:text="扫描二维码"
            android:textSize="16sp"
            android:backgroundTint="#5C6BC0"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- 已连接状态 -->
    <LinearLayout
        android:id="@+id/layout_connected"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="12dp">

        <!-- 电视显示预览 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="电视端显示"
            android:textSize="11sp"
            android:textColor="#555577"
            android:layout_marginBottom="3dp" />

        <TextView
            android:id="@+id/tv_tv_preview"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/input_bg"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="电视显示: "
            android:textSize="14sp"
            android:textColor="#9999CC"
            android:layout_marginBottom="10dp"
            android:ellipsize="end"
            android:singleLine="true" />

        <!-- 输入框 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="输入内容"
            android:textSize="11sp"
            android:textColor="#555577"
            android:layout_marginBottom="3dp" />

        <EditText
            android:id="@+id/et_input"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textSize="20sp"
            android:textColor="#EEEEFF"
            android:textColorHint="#333355"
            android:hint="在此输入..."
            android:gravity="top"
            android:inputType="textMultiLine|textNoSuggestions"
            android:layout_marginBottom="10dp" />

        <!-- 遥控器控制区 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="遥控电视"
            android:textSize="11sp"
            android:textColor="#555577"
            android:layout_marginBottom="6dp" />

        <!-- 方向键 + 返回键 布局 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <!-- 方向键十字 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- 上 -->
                <Button
                    android:id="@+id/btn_dpad_up"
                    android:layout_width="52dp"
                    android:layout_height="44dp"
                    android:text="▲"
                    android:textSize="16sp"
                    android:backgroundTint="#2A2A45"
                    android:textColor="#AAAACC"
                    android:layout_marginBottom="2dp" />

                <!-- 左中右 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="2dp">

                    <Button
                        android:id="@+id/btn_dpad_left"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:text="◀"
                        android:textSize="16sp"
                        android:backgroundTint="#2A2A45"
                        android:textColor="#AAAACC"
                        android:layout_marginEnd="2dp" />

                    <Button
                        android:id="@+id/btn_dpad_center"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:text="OK"
                        android:textSize="13sp"
                        android:backgroundTint="#388E3C"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="2dp" />

                    <Button
                        android:id="@+id/btn_dpad_right"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:text="▶"
                        android:textSize="16sp"
                        android:backgroundTint="#2A2A45"
                        android:textColor="#AAAACC" />

                </LinearLayout>

                <!-- 下 -->
                <Button
                    android:id="@+id/btn_dpad_down"
                    android:layout_width="52dp"
                    android:layout_height="44dp"
                    android:text="▼"
                    android:textSize="16sp"
                    android:backgroundTint="#2A2A45"
                    android:textColor="#AAAACC" />

            </LinearLayout>

            <!-- 右侧：返回键 + 退格键 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <Button
                    android:id="@+id/btn_back"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="← 返回"
                    android:textSize="14sp"
                    android:backgroundTint="#37474F"
                    android:textColor="#CCCCCC"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_backspace"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="⌫ 退格"
                    android:textSize="14sp"
                    android:backgroundTint="#37474F"
                    android:textColor="#CCCCCC"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_clear"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="清空"
                    android:textSize="14sp"
                    android:backgroundTint="#37474F"
                    android:textColor="#CCCCCC" />

            </LinearLayout>

        </LinearLayout>

        <!-- 底部：确认 / 取消 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_discard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="取消"
                android:textSize="15sp"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="10dp" />

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:text="✓  确认输入"
                android:textSize="16sp"
                android:backgroundTint="#388E3C"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
