<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F23">

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A35"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 TV 远程输入"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textSize="13sp"
            android:textColor="#888888" />

    </LinearLayout>

    <!-- Disconnected State -->
    <LinearLayout
        android:id="@+id/layout_disconnected"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="扫描电视上的二维码\n开始远程输入"
            android:textSize="18sp"
            android:textColor="#AAAACC"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_scan"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:text="扫描二维码"
            android:textSize="16sp"
            android:backgroundTint="#5C6BC0"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Connected State -->
    <LinearLayout
        android:id="@+id/layout_connected"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp">

        <!-- TV Preview -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="电视端显示内容"
            android:textSize="12sp"
            android:textColor="#666688"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_tv_preview"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="电视显示: "
            android:textSize="16sp"
            android:textColor="#9999CC"
            android:layout_marginBottom="16dp"
            android:ellipsize="end"
            android:singleLine="true" />

        <!-- Input field label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="在此输入文字"
            android:textSize="12sp"
            android:textColor="#666688"
            android:layout_marginBottom="4dp" />

        <!-- Main input EditText -->
        <EditText
            android:id="@+id/et_input"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/input_bg"
            android:padding="16dp"
            android:textSize="22sp"
            android:textColor="#EEEEFF"
            android:textColorHint="#444466"
            android:hint="开始输入..."
            android:gravity="top"
            android:inputType="textMultiLine|textNoSuggestions"
            android:layout_marginBottom="16dp" />

        <!-- Utility buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <ImageButton
                android:id="@+id/btn_backspace"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_backspace"
                android:background="@drawable/btn_secondary_bg"
                android:tint="#CCCCCC"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_clear"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_clear"
                android:background="@drawable/btn_secondary_bg"
                android:tint="#CCCCCC"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2" />

        </LinearLayout>

        <!-- Main action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_discard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="取消"
                android:textSize="16sp"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:text="✓  发送确认"
                android:textSize="18sp"
                android:backgroundTint="#388E3C"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
