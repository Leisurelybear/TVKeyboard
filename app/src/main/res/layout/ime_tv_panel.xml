<?xml version="1.0" encoding="utf-8"?>
<!--
  IME panel for TV side.
  - No confirm/clear/dismiss buttons (handled by remote control)
  - Semi-transparent background so content behind is visible
  - Takes up 75% screen height (set in TvInputMethodService)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#CC0A0A1E"
    android:padding="24dp">

    <!-- ── Left column: QR code + connection status ── -->
    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginEnd="24dp">

        <!-- Frosted-glass card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="#33FFFFFF"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手机扫码输入"
                android:textSize="13sp"
                android:textColor="#BBBBDD"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp" />

            <!-- QR code with white background -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/iv_qr_code"
                    android:layout_width="148dp"
                    android:layout_height="148dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_ip_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#6666AA"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp" />

            <!-- Status pill -->
            <TextView
                android:id="@+id/tv_client_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="等待扫码连接..."
                android:textSize="12sp"
                android:textColor="#888888"
                android:gravity="center" />

        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Remote control hint card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#33FFFFFF"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="遥控器"
                android:textSize="10sp"
                android:textColor="#5566AA"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="13sp"
                    android:textColor="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="确认键  提交输入"
                    android:textSize="12sp"
                    android:textColor="#AAAACC" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textSize="13sp"
                    android:textColor="#EF5350" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="返回键  收起输入法"
                    android:textSize="12sp"
                    android:textColor="#AAAACC" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Right column: live input display ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Section label + session count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="正在输入"
                android:textSize="13sp"
                android:textColor="#6677AA"
                android:letterSpacing="0.08" />

            <!-- Live session badge -->
            <TextView
                android:id="@+id/tv_session_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="#6677AA"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Input text display area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#22FFFFFF">

            <!-- Cursor accent bar on left edge -->
            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="#5C6BC0"
                android:layout_gravity="start" />

            <TextView
                android:id="@+id/tv_placeholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="等待手机输入..."
                android:textSize="22sp"
                android:textColor="#2A2A55"
                android:fontFamily="sans-serif-light" />

            <TextView
                android:id="@+id/tv_input_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="36sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:visibility="gone"
                android:maxLines="4"
                android:ellipsize="end"
                android:shadowColor="#66000033"
                android:shadowRadius="8"
                android:shadowDx="0"
                android:shadowDy="2" />

        </FrameLayout>

        <!-- Bottom hint strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1AFFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="输入内容将实时同步到此"
                android:textSize="11sp"
                android:textColor="#445588" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TV 远程输入法"
                android:textSize="10sp"
                android:textColor="#334466" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
