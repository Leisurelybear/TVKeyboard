<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0F0F23"
    android:padding="32dp"
    android:gravity="center_vertical">

    <!-- Left: QR Code + IP info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/card_bg"
        android:padding="24dp"
        android:layout_marginEnd="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="用手机扫描连接"
            android:textSize="18sp"
            android:textColor="#AAAACC"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/iv_qr_code"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="局域网地址"
            android:textSize="13sp"
            android:textColor="#666688" />

        <TextView
            android:id="@+id/tv_ip_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="---.---.---.---"
            android:textSize="15sp"
            android:textColor="#8888BB"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_client_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待手机连接..."
            android:textSize="14sp"
            android:textColor="#888888"
            android:drawablePadding="6dp" />

    </LinearLayout>

    <!-- Right: Input display + Buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Input Text Display -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/input_bg"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_placeholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="等待手机输入..."
                android:textSize="24sp"
                android:textColor="#444466"
                android:fontFamily="sans-serif-light" />

            <TextView
                android:id="@+id/tv_input_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text=""
                android:textSize="36sp"
                android:textColor="#EEEEFF"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone"
                android:ellipsize="end"
                android:maxLines="3" />

        </FrameLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_clear"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="清空"
                android:textSize="16sp"
                android:backgroundTint="#37474F"
                android:textColor="#CCCCCC"
                android:enabled="false"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="2"
                android:text="✓  确认输入"
                android:textSize="18sp"
                android:backgroundTint="#388E3C"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:enabled="false"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_dismiss"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="✕  收起"
                android:textSize="16sp"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
